class Solution {
    public int[] selectionSort(int[] nums) {
        int n = nums.length;

        for (int i = 0; i < n - 1; i++) {
            int mini = i; // Assume current element is minimum

            // Find the minimum element in the remaining array
            for (int j = i + 1; j < n; j++) {
                if (nums[j] < nums[mini]) {
                    mini = j;
                }
            }

            // Swap the found minimum element with nums[i]
            int temp = nums[mini];
            nums[mini] = nums[i];
            nums[i] = temp;
        }

        return nums;
    }
}
